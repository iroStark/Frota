# Local development
PORT=3000
DATABASE_URL=postgresql://localhost:5432/uhocha_controle
APP_STATE_ID=main

# Railway / produção (definir via dashboard Railway, não comitar)
# DATABASE_URL é fornecido pelo serviço Postgres (Variable Reference: ${{Postgres.DATABASE_URL}})
# PGSSL=true                # se DATABASE_URL não incluir sslmode=require e estiveres a usar URL pública
# UPLOADS_DIR=/data/uploads # caminho do Volume montado no serviço
